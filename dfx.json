{
  "canisters": {
    "points_ledger": {
      "type": "rust",
      "package": "points_ledger",
      "candid": "canisters/points_ledger/points_ledger.did"
    },
    "game_scores": {
      "type": "rust",
      "package": "game_scores",
      "candid": "canisters/game_scores/game_scores.did"
    },
    "stacker_frontend": {
