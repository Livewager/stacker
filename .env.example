# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# Points ledger canister (public — exposed to client)
NEXT_PUBLIC_POINTS_LEDGER_CANISTER_ID=aaaaa-aa

# IC host (local replica by default; use https://icp-api.io for mainnet)
NEXT_PUBLIC_IC_HOST=http://127.0.0.1:4943

# Server-side minter principal — used by /api/dunk/buy.
# Never prefix with NEXT_PUBLIC_ (would leak to the browser bundle).
DUNK_MINTER_PRINCIPAL=replace-with-your-minter-principal
